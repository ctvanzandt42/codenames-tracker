# Edge function secrets for local development.
# Copy to supabase/functions/.env — do NOT commit to git.
# SUPABASE_URL, SUPABASE_ANON_KEY, and SUPABASE_SERVICE_ROLE_KEY
# are injected automatically by the local edge runtime.

# Resend API key — required for the email-stats function to actually send mail.
# Leave blank to test the function without sending; it will error at the Resend step.
RESEND_API_KEY=
